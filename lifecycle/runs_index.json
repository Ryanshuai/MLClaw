{
  "_comment": "Quick lookup index for all runs across all stages. Updated after every run completes.",
  "_schema": {
    "run_id": "run_{YYYYMMDD}_{HHmmss}",
    "stage": "inference|training|...",
    "alias": "user-given short name",
    "description": "what this run was about",
    "status": "completed|failed|cancelled|running",
    "local_tags": [],
    "pipeline_tags": ["production", "staging", "validated", "baseline", "deprecated"],
    "created_at": "ISO timestamp",
    "duration_s": 0,
    "execution": "local|remote",
    "server": "server key from secrets.json or null",
    "metrics": {},
    "path": "stages/{stage}/runs/{run_id}"
  },
  "runs": []
}
